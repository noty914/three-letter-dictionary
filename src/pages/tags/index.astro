---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { getTagCatalogDescription } from '@/data/tag-catalog';
import { assertTagCatalogMatchesTerms } from '@/lib/tag-catalog-sync';
import { collectAllTags, countTermsWithTag, tagToParam } from '@/lib/tags';
import { withBase } from '@/lib/base-path';

const terms = await getCollection('terms');
assertTagCatalogMatchesTerms(terms);
const tags = collectAllTags(terms);
---

<BaseLayout title="タグ一覧" description="用語をタグから探せます。">
  <main class="container">
    <h1 class="page-title">タグ一覧</h1>
    <p class="lede">タグを選ぶと、そのタグが付いた用語だけが表示されます。</p>
    <ul class="tag-directory">
      {
        tags.map((tag) => {
          const description = getTagCatalogDescription(tag)!;
          const count = countTermsWithTag(terms, tag);
          return (
            <li class="tag-directory__row">
              <a class="tag-pill tag-pill--large" href={withBase(`tags/${tagToParam(tag)}/`)}>
                <span class="tag-pill__prefix">#</span>
                {tag}
              </a>
              <p class="tag-directory__desc">{description}</p>
              <span class="tag-directory__count">該当 {count} 件</span>
            </li>
          );
        })
      }
    </ul>
  </main>
</BaseLayout>
