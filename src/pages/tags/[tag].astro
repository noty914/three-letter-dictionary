---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { termSlug } from '@/lib/term-id';
import { collectAllTags, paramToTag, tagToParam } from '@/lib/tags';
import { withBase } from '@/lib/base-path';

export async function getStaticPaths() {
  const terms = await getCollection('terms');
  const tags = collectAllTags(terms);
  return tags.map((tag) => ({
    params: { tag: tagToParam(tag) },
  }));
}

const param = Astro.params.tag;
const rawTag = paramToTag(param);
const all = await getCollection('terms');
const terms = all
  .filter((t) => (t.data.tags ?? []).includes(rawTag))
  .sort((a, b) => termSlug(a.id).localeCompare(termSlug(b.id), 'en'));

const title = `タグ「${rawTag}」の用語`;
---

<BaseLayout title={title} description={`タグ ${rawTag} が付いた用語一覧。`}>
  <main class="container">
    <p class="lede" style="margin-bottom: 0.5rem;">
      <a href={withBase('tags/')}>← タグ一覧</a>
      {' · '}
      <a href={withBase('')}>トップ</a>
    </p>
    <h1 class="page-title">
      タグ: <span class="tag-pill tag-pill--inline">{rawTag}</span>
    </h1>
    <p class="lede">該当 {terms.length} 件</p>
    {
      terms.length === 0 ? (
        <p>このタグの用語はありません。</p>
      ) : (
        <ul class="card-list">
          {terms.map((t) => (
            <li>
              <a class="term-card__link" href={withBase(`terms/${termSlug(t.id)}/`)}>
                <span class="term-card__line">
                  <strong class="term-card__abbr">{t.data.titleJa}</strong>
                  <span class="term-card__en">（{t.data.titleEn}）</span>
                </span>
              </a>
            </li>
          ))}
        </ul>
      )
    }
  </main>
</BaseLayout>
