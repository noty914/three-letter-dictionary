---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { azKeyFromSlug, termSlug } from '@/lib/term-id';
import { withBase } from '@/lib/base-path';

export async function getStaticPaths() {
  const letters = 'abcdefghijklmnopqrstuvwxyz'.split('');
  return letters.map((letter) => ({ params: { letter } }));
}

const { letter } = Astro.params;
const all = await getCollection('terms');
const terms = all
  .filter((t) => termSlug(t.id).toLowerCase().startsWith(letter ?? ''))
  .sort((a, b) => termSlug(a.id).localeCompare(termSlug(b.id), 'en'));

const letterUpper = (letter ?? '').toUpperCase();
const title = `${letterUpper} で始まる用語`;
const azKey = /^[A-Z]$/.test(letterUpper) ? letterUpper : null;
---

<BaseLayout title={title} activeLetter={letter}>
  <main class="container">
    <h1 class="page-title letter-page-title" aria-label={azKey ? title : undefined}>
      {
        azKey ? (
          <span aria-hidden="true">
            <span class="letter-page-title__az" style={`color: var(--az-${azKey});`}>
              {azKey}
            </span>
            <span class="letter-page-title__rest">で始まる用語</span>
          </span>
        ) : (
          title
        )
      }
    </h1>
    <div class:list={['letter-results', azKey && 'letter-results--accent']}>
      <p class="lede letter-results__meta">該当 {terms.length} 件</p>
      {
        terms.length === 0 ? (
          <p class="letter-results__empty">
            まだこの文字では登録がありません。別の文字を選ぶか、用語を追加してください。
          </p>
        ) : (
          <ul class="card-list">
            {terms.map((t) => {
              const slug = termSlug(t.id);
              const cardAz = azKeyFromSlug(slug);
              return (
                <li>
                  <a
                    class:list={['term-card__link', cardAz && 'term-card__link--accent']}
                    style={cardAz ? `--term-accent: var(--az-${cardAz});` : undefined}
                    href={withBase(`terms/${slug}/`)}
                  >
                    <span class="term-card__line">
                      <strong class="term-card__abbr">{t.data.titleJa}</strong>
                      <span class="term-card__en">（{t.data.titleEn}）</span>
                    </span>
                  </a>
                </li>
              );
            })}
          </ul>
        )
      }
    </div>
  </main>
</BaseLayout>
