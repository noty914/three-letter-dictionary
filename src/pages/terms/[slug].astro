---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import MarkdownHtml from '@/components/MarkdownHtml.astro';
import TierAccordions from '@/components/TierAccordions.astro';
import RelatedTerms from '@/components/RelatedTerms.astro';
import { splitMarkdownTiers } from '@/lib/split-tiers';
import { missingRelatedSlugs } from '@/lib/related';
import { termSlug } from '@/lib/term-id';
import { buildEnglishTitleSegments } from '@/lib/english-initial';
import { withBase } from '@/lib/base-path';
import { SITE_NAME } from '@/config/site';
import { tagToParam } from '@/lib/tags';

export async function getStaticPaths() {
  const terms = await getCollection('terms');
  return terms.map((entry) => ({
    params: { slug: termSlug(entry.id) },
  }));
}

const { slug } = Astro.params;
if (!slug) {
  return Astro.redirect(withBase('404.html'));
}

const terms = await getCollection('terms');
const entry = terms.find((t) => termSlug(t.id) === slug);
if (!entry) {
  return Astro.redirect(withBase('404.html'));
}

const tiers = splitMarkdownTiers(entry.body ?? '');
const broken = missingRelatedSlugs(terms, entry.data.related);
if (broken.length > 0) {
  console.warn(
    `[terms/${entry.id}] related に存在しない id: ${broken.join(', ')}`,
  );
}

const letter = termSlug(entry.id)[0]?.toLowerCase() ?? undefined;
/** 検索結果・ブラウザタブ向け（「〇〇とは？」形式。サイト名は BaseLayout が付与） */
const pageTitle = `${entry.data.titleJa}とは？`;
const description = `「${entry.data.titleJa}」とは？ ${entry.data.titleEn}。①ざっくり概要・②ちょっと詳しく・③もっと知りたい人向けで解説。${SITE_NAME}。`;
const enSegments = buildEnglishTitleSegments(entry.data.titleEn, termSlug(entry.id));
---

<BaseLayout title={pageTitle} description={description} activeLetter={letter}>
  <main class="container">
    <article>
      <h1 class="page-title">{entry.data.titleJa}</h1>
      {
        enSegments ? (
          <p
            class="title-en-line"
            lang="en"
            aria-label={entry.data.titleEn}
          >
            <span aria-hidden="true">
              {
                enSegments.map((seg) =>
                  seg.type === 'text' ? (
                    <span class="title-en__plain">{seg.text}</span>
                  ) : (
                    <span
                      class="title-en__initial"
                      style={`color: var(--az-${seg.letter});`}
                    >
                      {seg.letter}
                    </span>
                  ),
                )
              }
            </span>
          </p>
        ) : (
          <p class="title-en-line" lang="en">
            {entry.data.titleEn}
          </p>
        )
      }
      {
        entry.data.tags?.length > 0 && (
          <p class="term-tags" aria-label="タグ">
            <span class="term-tags__label">タグ</span>
            {entry.data.tags.map((tag) => (
              <a class="tag-pill" href={withBase(`tags/${tagToParam(tag)}/`)}>
                <span class="tag-pill__prefix">#</span>
                {tag}
              </a>
            ))}
          </p>
        )
      }

      <section class="term-tier term-tier--static" aria-labelledby="primary-heading">
        <h2 id="primary-heading" class="tier-heading">
          ① 非エンジニア向けのざっくり概要
        </h2>
        <div class="tier-body">
          {
            tiers.primary ? (
              <MarkdownHtml markdown={tiers.primary} />
            ) : (
              <p class="lede">
                本文に <code>## ① 非エンジニア向けのざっくり概要</code> または <code>## 初級</code> 見出しがありません。{' '}
                <code>src/content/terms/{entry.id}</code> を確認してください。
              </p>
            )
          }
        </div>
      </section>

      <TierAccordions
        intermediateMd={tiers.intermediate}
        advancedMd={tiers.advanced}
      />

      <RelatedTerms relatedSlugs={entry.data.related} allTerms={terms} />

      <p class="lede" style="margin-top: 2rem;">
        <a href={withBase(`letter/${letter}/`)}>← {letter?.toUpperCase()} の索引へ</a>
        {' · '}
        <a href={withBase('')}>トップへ</a>
      </p>
    </article>
  </main>
</BaseLayout>
