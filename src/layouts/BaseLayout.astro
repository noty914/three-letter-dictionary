---
import '@/styles/global.css';
import AlphabetNav from '@/components/AlphabetNav.astro';
import ThemeToggle from '@/components/ThemeToggle.astro';
import { withBase } from '@/lib/base-path';
import { activeHeaderNav } from '@/lib/header-nav';
import {
  ALPHABET_NAV_VARIANT,
  SITE_DESCRIPTION,
  SITE_FOOTER,
  SITE_NAME,
} from '@/config/site';

interface Props {
  title: string;
  description?: string;
  activeLetter?: string;
  /** Open Graph の種類。用語詳細などでは `article` が適することが多い */
  ogType?: 'website' | 'article';
  /** Twitter カード。OG 画像があるときは `summary_large_image` が無難 */
  twitterCard?: 'summary' | 'summary_large_image';
}

const {
  title,
  description = SITE_DESCRIPTION,
  activeLetter,
  ogType = 'website',
  twitterCard = 'summary_large_image',
} = Astro.props;
const canonical = Astro.url.pathname;
const headerNavActive = activeHeaderNav(canonical, import.meta.env.BASE_URL);

/** 検索結果のタイトル用：ページ題にサイト名を付与（重複しないよう既に含む場合はそのまま） */
const documentTitle = title.includes(SITE_NAME)
  ? title
  : `${title} | ${SITE_NAME}`;
const canonicalUrl = new URL(canonical, Astro.site).href;
const ogImageUrl = new URL(withBase('images/brand-header.png'), Astro.site).href;
const gaId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID?.trim();
const useGa = Boolean(gaId);
---

<!doctype html>
<html lang="ja" data-theme="dark" data-alphabet-style={ALPHABET_NAV_VARIANT}>
  <head>
    <meta charset="utf-8" />
    <script is:inline>
      (function () {
        try {
          var m = localStorage.getItem('theme');
          var root = document.documentElement;
          if (m === 'light' || m === 'dark' || m === 'system') {
            root.setAttribute('data-theme', m);
            root.style.colorScheme =
              m === 'dark' ? 'dark' : m === 'light' ? 'light' : 'light dark';
          } else {
            root.setAttribute('data-theme', 'dark');
            root.style.colorScheme = 'dark';
          }
        } catch (e) {
          document.documentElement.setAttribute('data-theme', 'dark');
          document.documentElement.style.colorScheme = 'dark';
        }
      })();
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{documentTitle}</title>
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={documentTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta name="twitter:card" content={twitterCard} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:title" content={documentTitle} />
    <meta name="twitter:description" content={description} />
    <link rel="icon" type="image/x-icon" href={withBase('favicon.ico')} />
    <link rel="icon" type="image/png" sizes="16x16" href={withBase('favicon-16x16.png')} />
    <link rel="icon" type="image/png" sizes="32x32" href={withBase('favicon-32x32.png')} />
    <link rel="apple-touch-icon" sizes="180x180" href={withBase('apple-touch-icon.png')} />
    <link rel="manifest" href={withBase('site.webmanifest')} />
    {
      useGa && (
        <>
          <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>
          <script is:inline define:vars={{ gaId }}>
            window.dataLayer = window.dataLayer || [];
            function gtag(){dataLayer.push(arguments);}
            gtag('js', new Date());
            gtag('config', gaId);
          </script>
        </>
      )
    }
  </head>
  <body>
    <header class="site-header site-header--dictionary">
      <div class="inner">
        <a class="brand brand__link" href={withBase('')}>
          <span class="brand__mark-wrap">
            <img
              class="brand__mark"
              src={withBase('images/brand-header.png')}
              alt={SITE_NAME}
              decoding="async"
            />
          </span>
        </a>
        <div class="header-actions">
          <nav class="header-nav header-nav--index" aria-label="メイン">
            <a
              class:list={['header-tab', headerNavActive === 'top' && 'is-active']}
              href={withBase('')}
              aria-current={headerNavActive === 'top' ? 'page' : undefined}
            >
              トップ
            </a>
            <a
              class:list={['header-tab', headerNavActive === 'tags' && 'is-active']}
              href={withBase('tags/')}
              aria-current={headerNavActive === 'tags' ? 'page' : undefined}
            >
              タグ
            </a>
          </nav>
          <ThemeToggle />
        </div>
      </div>
    </header>
    <slot name="before-alphabet" />
    <AlphabetNav activeLetter={activeLetter} />
    <slot />
    <footer class="site-footer">
      <p class="site-footer__links">
        <a href={withBase('privacy/')}>プライバシーポリシー</a>
      </p>
      <small>{SITE_FOOTER}</small>
    </footer>
  </body>
</html>
