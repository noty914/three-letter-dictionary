---
import '@/styles/global.css';
import AlphabetNav from '@/components/AlphabetNav.astro';
import ThemeToggle from '@/components/ThemeToggle.astro';
import { withBase } from '@/lib/base-path';
import { SITE_DESCRIPTION, SITE_FOOTER, SITE_NAME } from '@/config/site';

interface Props {
  title: string;
  description?: string;
  activeLetter?: string;
}

const { title, description = SITE_DESCRIPTION, activeLetter } = Astro.props;
const canonical = Astro.url.pathname;

/** 検索結果のタイトル用：ページ題にサイト名を付与（重複しないよう既に含む場合はそのまま） */
const documentTitle = title.includes(SITE_NAME)
  ? title
  : `${title} | ${SITE_NAME}`;
const canonicalUrl = new URL(canonical, Astro.site).href;
const gaId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID?.trim();
const useGa = Boolean(gaId);
---

<!doctype html>
<html lang="ja" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <script is:inline>
      (function () {
        try {
          var m = localStorage.getItem('theme');
          var root = document.documentElement;
          if (m === 'light' || m === 'dark' || m === 'system') {
            root.setAttribute('data-theme', m);
            root.style.colorScheme =
              m === 'dark' ? 'dark' : m === 'light' ? 'light' : 'light dark';
          } else {
            root.setAttribute('data-theme', 'dark');
            root.style.colorScheme = 'dark';
          }
        } catch (e) {
          document.documentElement.setAttribute('data-theme', 'dark');
          document.documentElement.style.colorScheme = 'dark';
        }
      })();
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{documentTitle}</title>
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={documentTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={documentTitle} />
    <meta name="twitter:description" content={description} />
    {
      useGa && (
        <>
          <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>
          <script is:inline>
            {`window.dataLayer = window.dataLayer || [];
function gtag(){dataLayer.push(arguments);}
gtag('js', new Date());
gtag('config', '${gaId}');`}
          </script>
        </>
      )
    }
  </head>
  <body>
    <header class="site-header">
      <div class="inner">
        <div class="brand">
          <a href={withBase('')}>{SITE_NAME}</a>
        </div>
        <div class="header-actions">
          <nav class="header-nav" aria-label="メイン">
            <a href={withBase('')}>トップ</a>
            <a href={withBase('tags/')}>タグ</a>
          </nav>
          <ThemeToggle />
        </div>
      </div>
    </header>
    <AlphabetNav activeLetter={activeLetter} />
    <slot />
    <footer class="site-footer">
      <p class="site-footer__links">
        <a href={withBase('privacy/')}>プライバシーポリシー</a>
      </p>
      <small>{SITE_FOOTER}</small>
    </footer>
  </body>
</html>
